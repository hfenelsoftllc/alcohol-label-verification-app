# ============================================================================
# Alcohol Label Verification — environment configuration
# Copy this file to `.env` and adjust. NEVER commit `.env` (it is gitignored).
# ============================================================================

# ---- OCR / Vision ----------------------------------------------------------
# Claude Vision API key. Required unless OCR_MODE=local (air-gapped operation).
# Injected via your secrets manager / GitHub Secrets in CI — never hardcode it.
ANTHROPIC_API_KEY=

# OCR engine selection:
#   auto  = try Claude Vision, fall back to local Tesseract on network failure
#   local = force local Tesseract only (air-gapped; no API key needed)
OCR_MODE=auto

# Claude model used for vision extraction.
CLAUDE_VISION_MODEL=claude-opus-4-8

# Seconds to wait on the Vision API before failing over to Tesseract.
# The adapter does not retry (max_retries=0), so failover is immediate.
OCR_API_TIMEOUT_SECONDS=30

# Confidence score (0-100) recorded on results extracted via Claude Vision.
OCR_CLAUDE_CONFIDENCE=95

# Confidence score (0-100) recorded on results extracted via the local
# Tesseract fallback (deliberately lower — used to flag results for review).
OCR_TESSERACT_CONFIDENCE=60

# ---- Backend ---------------------------------------------------------------
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# In-memory session expiry (hours). Also used as the session cookie's
# Max-Age (ISSUE 3.7).
SESSION_TTL_HOURS=4

# Optional HMAC key for signing session-id cookies (ISSUE 3.7), e.g.
#   openssl rand -hex 32
# If unset, a random key is generated once per process — fine for a single
# instance (everything is in-memory and restarts clear all sessions
# anyway), but set this explicitly if you run multiple backend instances
# behind a load balancer so cookies validate across all of them.
# If you do set it: use a strong, unique, randomly-generated value
# (e.g. `openssl rand -hex 32`) and NEVER reuse the same value across
# environments (dev/staging/prod) — a shared or weak key allows
# session-cookie forgery (see docs/fedramp/THREAT-MODEL.md, T-S2).
SESSION_SECRET_KEY=

# Maximum size of a single uploaded label image, in MB.
MAX_IMAGE_MB=20

# Maximum cumulative image size for one /verify/batch request, in MB.
# On Vercel, lower this (e.g. 4) to stay under the platform's request body
# size limit for serverless functions.
MAX_BATCH_MB=500

# Number of labels processed concurrently within a single batch job
# (asyncio.Semaphore in backend/batch/orchestrator.py). Tune down on
# memory-constrained hosts, up on hosts with more CPU/RAM headroom.
BATCH_MAX_WORKERS=10

# Redis connection URL for cross-invocation session/job storage. Leave blank
# to use the in-process dict store — fine for Docker Compose/local dev (one
# long-lived backend instance), but REQUIRED on Vercel, where each request
# may hit a different serverless instance and /jobs/* + /verify/batch need a
# shared store to work. To run Redis locally: `docker compose --profile
# with-redis up` and set REDIS_URL=redis://redis:6379/0. On Vercel, use the
# rediss://... TLS URL from the Upstash Marketplace integration.
REDIS_URL=

# ---- Frontend --------------------------------------------------------------
# Base URL the SPA calls. Default `/api` is reverse-proxied to the backend by
# nginx (same-origin, no CORS). Baked in at build time.
VITE_API_URL=/api

# ---- Host ports ------------------------------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8000
